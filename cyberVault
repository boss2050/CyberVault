  <script>
    // ==================== CRYPTOGRAPHICALLY SECURE RANDOM FUNCTION ====================
    function secureRandomInt(max) {
      const randomBuffer = new Uint32Array(1);
      crypto.getRandomValues(randomBuffer);
      return randomBuffer[0] % max;
    }
    
    function secureRandomChar(pool) {
      return pool[secureRandomInt(pool.length)];
    }

    // ==================== BREACH DATABASE ====================
    const BREACH_SET = new Set([
      "123456","password","12345678","qwerty","123456789","12345","1234","111111","1234567","dragon","123123","baseball","abc123","football","monkey","letmein","shadow","master","666666","qwertyuiop","123321","mustang","1234567890","michael","654321","pussy","superman","1qaz2wsx","password123","admin","trustno1","jesus","sunshine","iloveyou","princess","ashley","bailey","passw0rd","shadow","qwerty123","hello","freedom","whatever","nicole","chelsea","lovely","matrix","secret","google","000000","987654321","q1w2e3r4","welcome","login","admin123","root","toor","oracle","test","test123","123qwe","1q2w3e","zaq12wsx","passpass","!@#$%^&*","password1","changeme","qazwsxedc","iloveyou123","sunshine1","princess1","qwerty12345","football123","monkey123","welcome123","adminadmin","qwerty123456","letmein123","trustno1","123123123","9876543210"
    ]);
    function isBreached(pwd) { if(!pwd) return false; return BREACH_SET.has(pwd.toLowerCase()) || BREACH_SET.has(pwd); }

    // Analyzer Helpers
    function analyzeStats(pwd) {
      let upper=0,lower=0,digits=0,symbols=0;
      for(let ch of pwd){if(ch>='A'&&ch<='Z') upper++;else if(ch>='a'&&ch<='z') lower++;else if(ch>='0'&&ch<='9') digits++;else symbols++;}
      return {upper,lower,digits,symbols,length:pwd.length};
    }
    function calcEntropy(pwd){
      let cs=0;
      if(/[a-z]/.test(pwd)) cs+=26;
      if(/[A-Z]/.test(pwd)) cs+=26;
      if(/[0-9]/.test(pwd)) cs+=10;
      if(/[^a-zA-Z0-9]/.test(pwd)) cs+=33;
      if(cs===0||pwd.length===0) return 0;
      return +(pwd.length * Math.log2(cs)).toFixed(1);
    }
    function crackTimeEstimate(entropy,len){
      if(len===0) return "—";
      let guesses = Math.pow(2, entropy);
      let sec = guesses / 100_000_000_000;
      if(sec<0.001) return "<0.001 sec";
      if(sec<60) return sec.toFixed(2)+" sec";
      let min=sec/60; if(min<60) return min.toFixed(1)+" min";
      let hrs=min/60; if(hrs<24) return hrs.toFixed(1)+" hours";
      let days=hrs/24; if(days<365) return days.toFixed(1)+" days";
      let yrs=days/365; if(yrs<1000) return yrs.toFixed(1)+" years";
      if(yrs<100000) return (yrs/1000).toFixed(1)+"k years";
      return "∞ (very secure)";
    }
    function computeSecurityScore(pwd, entropy, isCommon){
      if(pwd.length===0) return 0;
      if(isCommon && pwd.length>0) return 12;
      let score=0;
      if(pwd.length>=8) score+=15;
      if(pwd.length>=12) score+=10;
      if(pwd.length>=16) score+=10;
      if(/[A-Z]/.test(pwd)) score+=12;
      if(/[a-z]/.test(pwd)) score+=5;
      if(/[0-9]/.test(pwd)) score+=12;
      if(/[^A-Za-z0-9]/.test(pwd)) score+=20;
      if(entropy>50) score+=10;
      if(entropy>70) score+=6;
      return Math.min(100, score);
